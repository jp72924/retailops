# RetailOps Backend environment example.
# Copy values into your shell, process manager, or hosting environment.
# Django does not auto-load this file.

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=replace-this-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# External RetailOps Kiosk origins allowed to call /api/v1/kiosk/.
KIOSK_CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Local default: leave database variables unset for SQLite db.sqlite3.
# PostgreSQL option:
# DATABASE_URL=postgresql://retailops_app:password@127.0.0.1:5432/retailops?sslmode=disable
# DB_CONN_MAX_AGE=60

# Local default: leave storage variables unset for local media/.
# S3-compatible option:
# MEDIA_STORAGE_BACKEND=s3
# MEDIA_S3_ENDPOINT_URL=http://127.0.0.1:9000
# MEDIA_S3_ACCESS_KEY_ID=retailops
# MEDIA_S3_SECRET_ACCESS_KEY=replace-me
# MEDIA_S3_PUBLIC_BUCKET_NAME=<product-assets-bucket>
# MEDIA_S3_PRIVATE_BUCKET_NAME=<receipt-documents-bucket>
# MEDIA_S3_REGION_NAME=us-east-1
# MEDIA_S3_PRODUCT_PUBLIC=true
# MEDIA_S3_RECEIPT_SIGNED_URLS=true

# Google Cloud Storage option:
# MEDIA_STORAGE_BACKEND=gcs
# MEDIA_GCS_PROJECT_ID=<media-project-id>
# MEDIA_GCS_PUBLIC_BUCKET_NAME=<product-assets-bucket>
# MEDIA_GCS_PRIVATE_BUCKET_NAME=<receipt-documents-bucket>

# MCP server connection to this backend.
RETAILOPS_BASE_URL=http://127.0.0.1:8000/api/v1
RETAILOPS_API_TOKEN=
RETAILOPS_TIMEOUT=30
